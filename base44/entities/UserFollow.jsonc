{
  "name": "UserFollow",
  "type": "object",
  "properties": {
    "following_email": {
      "type": "string",
      "description": "E-Mail des gefolgten Nutzers"
    }
  },
  "required": [
    "following_email"
  ],
  "rls": {
    "create": true,
    "read": true,
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}